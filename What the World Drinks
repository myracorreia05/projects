const tt=document.getElementById('tooltip');
function showTT(d,e){
  document.getElementById('tt-name').textContent=d.country;
  document.getElementById('tt-region').textContent=d.region;
  document.getElementById('tt-beer').textContent=d.beer_servings+' servings';
  document.getElementById('tt-spirits').textContent=d.spirit_servings+' servings';
  document.getElementById('tt-wine').textContent=d.wine_servings+' servings';
  document.getElementById('tt-total').textContent=d.total_litres_of_pure_alcohol.toFixed(1)+' L';
  document.getElementById('tt-dom').textContent=d.dominant;
  tt.style.display='block';
  posTT(e);
}
function posTT(e){
  const x=e.clientX+16,y=e.clientY-10;
  tt.style.left=(x+200>window.innerWidth?x-220:x)+'px';
  tt.style.top=y+'px';
}
document.addEventListener('mousemove',e=>{if(tt.style.display==='block')posTT(e)});
function hideTT(){tt.style.display='none'}
function avg(arr,k){return arr.reduce((s,d)=>s+d[k],0)/arr.length}
function topN(k,n){return[...RAW].sort((a,b)=>b[k]-a[k]).slice(0,n)}
const domColor={beer:'var(--beer)',spirits:'var(--spirits)',wine:'var(--wine)',none:'var(--dim)'};

// ─ SCROLL PROGRESS ─
window.addEventListener('scroll',()=>{
  const s=document.documentElement.scrollHeight-window.innerHeight;
  document.getElementById('progress').style.width=(window.scrollY/s*100)+'%';
});

// ─ REVEAL ON SCROLL ─
const observer=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');observer.unobserve(e.target)}});
},{threshold:0.12});
document.querySelectorAll('.reveal').forEach(el=>observer.observe(el));

// ─ BAR CHART BUILDER ─
function makeBarChart(containerId,data,keyFn,colorFn,maxVal){
  const wrap=document.getElementById(containerId);
  wrap.innerHTML='';
  const maxV=maxVal||Math.max(...data.map(keyFn));
  data.forEach(d=>{
    const val=keyFn(d);
    const pct=(val/maxV*100).toFixed(1);
    const row=document.createElement('div');
    row.className='bar-row';
    row.innerHTML=`<div class="bar-name" title="${d.country}">${d.country}</div><div class="bar-track"><div class="bar-fill" style="background:${colorFn(d)};width:0%" data-w="${pct}"></div></div><div class="bar-val">${val}</div>`;
    row.addEventListener('mouseenter',e=>showTT(d,e));
    row.addEventListener('mouseleave',hideTT);
    wrap.appendChild(row);
  });
  setTimeout(()=>wrap.querySelectorAll('.bar-fill').forEach(b=>{b.style.width=b.dataset.w+'%'}),100);
}

