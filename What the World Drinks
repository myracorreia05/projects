  const binGen=d3.bin().domain([0,15]).thresholds(30);
  const bins=binGen(vals);
  const yS=d3.scaleLinear().domain([0,d3.max(bins,b=>b.length)]).range([H-30,10]);
  const colors=['rgba(212,147,30,','rgba(192,57,43,','rgba(142,68,173,'];
  svg.selectAll('rect').data(bins).join('rect')
    .attr('x',d=>xS(d.x0)+1).attr('width',d=>Math.max(0,xS(d.x1)-xS(d.x0)-2))
    .attr('y',d=>yS(d.length)).attr('height',d=>H-30-yS(d.length))
    .attr('fill',d=>{
      const mid=(d.x0+d.x1)/2;
      if(mid<5)return 'rgba(212,147,30,0.6)';
      if(mid<10)return 'rgba(192,57,43,0.6)';
      return 'rgba(142,68,173,0.7)';
    }).attr('rx',2);
  // avg line
  const globalAvg=avg(RAW,'total_litres_of_pure_alcohol');
  svg.append('line').attr('x1',xS(globalAvg)).attr('x2',xS(globalAvg)).attr('y1',8).attr('y2',H-30).attr('stroke','rgba(232,201,122,0.7)').attr('stroke-width',1.5).attr('stroke-dasharray','3,3');
})();

// ─ SECTION 4: DRINK TYPE CHARTS ─
makeBarChart('bar-beer',topN('beer_servings',12),d=>d.beer_servings,()=>'var(--beer)',400);
makeBarChart('bar-spirits',topN('spirit_servings',12),d=>d.spirit_servings,()=>'var(--spirits)',450);
makeBarChart('bar-wine',topN('wine_servings',16),d=>d.wine_servings,()=>'var(--wine)',380);

// ─ HEATMAP ─
(function(){
  const top20=topN('total_litres_of_pure_alcohol',20);
  const maxB=Math.max(...top20.map(d=>d.beer_servings));
  const maxS=Math.max(...top20.map(d=>d.spirit_servings));
  const maxW=Math.max(...top20.map(d=>d.wine_servings));
  const maxT=Math.max(...top20.map(d=>d.total_litres_of_pure_alcohol));
  function hClass(val,mx){const r=val/mx;if(r<0.1)return'heat-0';if(r<0.3)return'heat-1';if(r<0.5)return'heat-2';if(r<0.7)return'heat-3';if(r<0.85)return'heat-4';return'heat-5';}
  const tbl=document.getElementById('heatmap-table');
  tbl.innerHTML=`<thead><tr><th>Country</th><th>Beer</th><th>Spirits</th><th>Wine</th><th>Total L</th></tr></thead>`;
  const tb=document.createElement('tbody');
  top20.forEach(d=>{
    const tr=document.createElement('tr');
    tr.innerHTML=`<td>${d.country}</td><td class="${hClass(d.beer_servings,maxB)}">${d.beer_servings}</td><td class="${hClass(d.spirit_servings,maxS)}">${d.spirit_servings}</td><td class="${hClass(d.wine_servings,maxW)}">${d.wine_servings}</td><td class="${hClass(d.total_litres_of_pure_alcohol,maxT)}">${d.total_litres_of_pure_alcohol}</td>`;
    tr.addEventListener('mouseenter',e=>showTT(d,e));
    tr.addEventListener('mouseleave',hideTT);
    tb.appendChild(tr);
  });
  tbl.appendChild(tb);
})();

// ─ WORLD MAP ─
const MAP_CONFIG={
  total:{key:'total_litres_of_pure_alcohol',max:14.4,colors:['#1a1714','#6b3c14','#d4931e'],label:'Litres pure alcohol / person / yr'},
  beer:{key:'beer_servings',max:376,colors:['#1a1714','#5a3a0a','#d4931e'],label:'Beer servings / year'},
  spirits:{key:'spirit_servings',max:438,colors:['#1a1714','#5a1a14','#c0392b'],label:'Spirit servings / year'},
  wine:{key:'wine_servings',max:370,colors:['#1a1714','#3d1a54','#8e44ad'],label:'Wine servings / year'}
};
const NAME_MAP={'united states of america':'USA','russia':'Russian Federation','south korea':'South Korea','north korea':'North Korea','czechia':'Czech Republic','united republic of tanzania':'Tanzania','democratic republic of the congo':'DR Congo','republic of the congo':'Congo',"côte d'ivoire":"Cote d'Ivoire",'ivory coast':"Cote d'Ivoire",'cape verde':'Cabo Verde','swaziland':'Swaziland','eswatini':'Swaziland','trinidad and tobago':'Trinidad & Tobago','antigua and barbuda':'Antigua & Barbuda','saint kitts and nevis':'St. Kitts & Nevis','saint lucia':'St. Lucia','saint vincent and the grenadines':'St. Vincent & the Grenadines','sao tome and principe':'Sao Tome & Principe','bosnia and herzegovina':'Bosnia-Herzegovina','republic of moldova':'Moldova','moldova':'Moldova','north macedonia':'Macedonia','guinea-bissau':'Guinea-Bissau','equatorial guinea':'Equatorial Guinea','central african republic':'Central African Republic','papua new guinea':'Papua New Guinea','solomon islands':'Solomon Islands','marshall islands':'Marshall Islands','timor-leste':'Timor-Leste'};
const mapLookup={};RAW.forEach(d=>{mapLookup[d.country.toLowerCase()]=d});
let currentMapMetric='total';
function renderLegend(m){
  const cfg=MAP_CONFIG[m];
  const steps=7;
  const cScale=d3.scaleLinear().domain([0,cfg.max]).range([cfg.colors[0],cfg.colors[2]]);
  let swatches='';
  for(let i=0;i<steps;i++)swatches+=`<span style="display:inline-block;width:24px;height:8px;background:${cScale(cfg.max*i/(steps-1))}"></span>`;
  document.getElementById('map-legend').innerHTML=`<span>0</span>${swatches}<span>${cfg.max}+</span><span style="margin-left:12px;font-size:8px;opacity:0.5">${cfg.label}</span>`;
}
function renderMap(m){
  renderLegend(m);
  const cfg=MAP_CONFIG[m];
  const wrap=document.getElementById('map-wrap');
  wrap.innerHTML='<div id="map-loading" style="padding:40px;text-align:center;font-family:JetBrains Mono,monospace;font-size:11px;color:var(--dim)">Loading…</div>';
  d3.json('https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json').then(world=>{
    wrap.innerHTML='';
    const W=wrap.clientWidth||960,H=Math.round(W*0.5);
    const proj=d3.geoNaturalEarth1().scale(W/6.1).translate([W/2,H/2]);
    const path=d3.geoPath().projection(proj);
    const cScale=d3.scaleLinear().domain([0,cfg.max]).range([cfg.colors[0],cfg.colors[2]]).clamp(true);
    const svg=d3.select(wrap).append('svg').attr('viewBox',`0 0 ${W} ${H}`).attr('width','100%').style('display','block');
    svg.selectAll('path').data(topojson.feature(world,world.objects.countries).features).join('path')
      .attr('d',path)
      .attr('fill',feat=>{
        const n=(feat.properties.name||'').toLowerCase();
        const rec=mapLookup[NAME_MAP[n]?.toLowerCase()]||mapLookup[n];
        return rec?cScale(rec[cfg.key]):'#1e1b17';
      })
      .attr('stroke','rgba(255,240,200,0.06)').attr('stroke-width',0.4).style('cursor','pointer')
      .on('mouseenter',(event,feat)=>{
        const n=(feat.properties.name||'').toLowerCase();
        const rec=mapLookup[NAME_MAP[n]?.toLowerCase()]||mapLookup[n];
        if(rec)showTT(rec,event);
        d3.select(event.currentTarget).attr('stroke','rgba(255,240,200,0.4)').attr('stroke-width',1.2);
      })
      .on('mouseleave',event=>{hideTT();d3.select(event.currentTarget).attr('stroke','rgba(255,240,200,0.06)').attr('stroke-width',0.4)});
  }).catch(()=>{wrap.innerHTML='<div style="padding:24px;font-family:JetBrains Mono,monospace;font-size:11px;color:var(--dim)">Map unavailable — check your connection.</div>'});
}
renderMap('total');
window.setMap=(m,btn)=>{
  document.querySelectorAll('.map-btn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');currentMapMetric=m;renderMap(m);
};

// ─ TABLE ─
let tSort='total_litres_of_pure_alcohol',tDir=-1,tPage=0,tQ='',tRegion='all';
const PER=18;
function updateTable(){
  tQ=document.getElementById('tbl-search').value.toLowerCase();
  tPage=0;renderTable();
}
window.updateTable=updateTable;
function setFilter(r,btn){
  document.querySelectorAll('.tbl-f-btn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');tRegion=r;tPage=0;renderTable();
}
window.setFilter=setFilter;
function sortTable(k){
  if(tSort===k)tDir*=-1;else{tSort=k;tDir=-1;}tPage=0;renderTable();
}
window.sortTable=sortTable;
function goPage(p){tPage=p;renderTable();}
window.goPage=goPage;
function renderTable(){
  let rows=[...RAW];
  if(tRegion!=='all')rows=rows.filter(d=>d.region===tRegion);
  if(tQ)rows=rows.filter(d=>d.country.toLowerCase().includes(tQ)||d.region.toLowerCase().includes(tQ));
  rows.sort((a,b)=>{
    if(tSort==='country')return tDir*a.country.localeCompare(b.country);
    if(tSort==='region')return tDir*a.region.localeCompare(b.region);
    if(tSort==='dominant')return tDir*a.dominant.localeCompare(b.dominant);
    return tDir*(b[tSort]-a[tSort]);
  });
  document.getElementById('tbl-count').textContent=rows.length+' countries';
  const pg=rows.slice(tPage*PER,(tPage+1)*PER);
  const maxB2=376,maxS2=438,maxW2=370;
  const tb=document.getElementById('tbl-body');
  tb.innerHTML=pg.map(d=>`
    <tr>
      <td>${d.country}</td>
      <td style="font-size:11px;color:var(--dim)">${d.region}</td>
      <td><span class="pill-dom pill-${d.dominant}">${d.dominant}</span></td>
      <td class="num"><span class="mini-spark"><span style="height:${Math.max(3,d.beer_servings/maxB2*14)}px;background:var(--beer)"></span></span>${d.beer_servings}</td>
      <td class="num"><span class="mini-spark"><span style="height:${Math.max(3,d.spirit_servings/maxS2*14)}px;background:var(--spirits)"></span></span>${d.spirit_servings}</td>
      <td class="num"><span class="mini-spark"><span style="height:${Math.max(3,d.wine_servings/maxW2*14)}px;background:var(--wine)"></span></span>${d.wine_servings}</td>
      <td class="num" style="color:var(--gold);font-weight:500">${d.total_litres_of_pure_alcohol.toFixed(1)}</td>
    </tr>`).join('');
  const total=Math.ceil(rows.length/PER);
  document.getElementById('tbl-page-info').textContent=`Page ${tPage+1} of ${total} · ${rows.length} rows`;
  let btns='';
  if(tPage>0)btns+=`<button class="pg-b" onclick="goPage(${tPage-1})">←</button>`;
  const start=Math.max(0,tPage-2),end=Math.min(total-1,tPage+2);
  for(let p=start;p<=end;p++)btns+=`<button class="pg-b ${p===tPage?'on':''}" onclick="goPage(${p})">${p+1}</button>`;
  if(tPage<total-1)btns+=`<button class="pg-b" onclick="goPage(${tPage+1})">→</button>`;
  document.getElementById('tbl-pg-btns').innerHTML=btns;
  // sort indicators
  ['country','region','dominant','beer','spirits','wine','total'].forEach(k=>{
    const colMap={country:'country',region:'region',dominant:'dominant',beer:'beer_servings',spirits:'spirit_servings',wine:'wine_servings',total:'total_litres_of_pure_alcohol'};
    const th=document.getElementById('th-'+k);
    if(th)th.className=colMap[k]===tSort?(tDir===1?'sort-a':'sort-d'):'';
  });
}
renderTable();
</script>
